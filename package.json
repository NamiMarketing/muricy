{
  "name": "muricy",
  "version": "1.0.0",
  "description": "Site da clinica Muricy",
  "main": "index.js",
  "scripts": {
    "build": "npm-run-all build:css build:html",
    "build:css": "node-sass --include-path scss src/sass/ -o public/css --output-style compressed",
    "build:html": "eleventy",
    "dev": "npm-run-all --parallel watch:css watch:html",
    "watch:css": "node-sass -w src/sass   -o src/css --output-style compressed",
    "watch:html": "eleventy --serve"
  },
  "keywords": [],
  "author": "Nami",
  "license": "ISC",
  "dependencies": {
    "node-sass": "^9.0.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.69.5"
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "prettier": "^3.1.1"
  },
  "repository": "git@github.com:NamiSites/muricy.git"
}