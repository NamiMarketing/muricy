    // Seleciona todos os modais na ordem
    const modals = document.querySelectorAll(".tecnologia-modal");
    // Seleciona todos os botões de fechar dentro dos modais
    const closeButtons = document.querySelectorAll(".modal-close");
  
    openButtons.forEach((button, index) => {
      button.addEventListener("click", (e) => {
        e.preventDefault(); // previne clique em links
        // Fecha todos os modais antes de abrir o novo
        modals.forEach(modal => modal.classList.remove("active-modal"));
        // Abre o modal correspondente
        modals[index].classList.add("active-modal");
      });
    });
  
    // Fecha ao clicar no botão de fechar
    closeButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        btn.closest(".tecnologia-modal").classList.remove("active-modal");
      });
    });
  
    // Fecha se clicar fora do conteúdo do modal
    modals.forEach(modal => {
      modal.addEventListener("click", (e) => {
        if (e.target === modal) {
          modal.classList.remove("active-modal");
        }
      });
    });
  </script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
      const button = document.querySelector('.read-more-btn');
      const box = document.getElementById('testemunho');
  
      button.addEventListener('click', function () {
        box.classList.toggle('expanded');
        button.textContent = box.classList.contains('expanded') ? 'Mostrar menos' : 'Continue lendo';
      });
    });
  </script>